<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ══════════════ HEADER ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒 Kreyzi Obfuscator"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textSize="11sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ══════════════ INPUT CARD ══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/accent_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Card title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="INPUT  SOURCE"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:textColor="@color/accent_green"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvInputCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 chars / 0 lines"
                        android:textSize="10sp"
                        android:textColor="@color/text_dim"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Input EditText -->
                <EditText
                    android:id="@+id/etInput"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/code_bg"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:hint="-- Paste your Lua script here…"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:padding="10dp"
                    android:scrollbars="vertical"
                    android:overScrollMode="always"/>

                <!-- Input buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoadFile"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="📂 File"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:textColor="@color/accent_green"
                        app:strokeColor="@color/accent_green"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPaste"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="📋 Paste"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:textColor="@color/accent_green"
                        app:strokeColor="@color/accent_green"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearInput"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textSize="12sp"
                        android:textColor="@color/text_dim"
                        app:strokeColor="@color/text_dim"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════ CONFIG CARD ══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CONFIG"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/accent_purple"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:paddingBottom="10dp"/>

                <!-- Preset label + spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preset"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp"/>

                <Spinner
                    android:id="@+id/spPreset"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@color/code_bg"
                    android:padding="8dp"/>

                <!-- Lua Version -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lua Version"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"/>

                <RadioGroup
                    android:id="@+id/rgLuaVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbDefault"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Config default"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_purple"
                        android:checked="true"
                        android:textSize="12sp"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbLuaU"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LuaU"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_purple"
                        android:textSize="12sp"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbLua51"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lua 5.1"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_purple"
                        android:textSize="12sp"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════ OBFUSCATE BUTTON ══════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnObfuscate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="🔥  Obfuscate"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:fontFamily="monospace"
            app:backgroundTint="@color/accent_green"
            android:textColor="@color/bg_dark"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:progressTint="@color/accent_green"/>

        <!-- ══════════════ LOGS CARD ══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/text_dim"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOGS"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_dim"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:paddingBottom="8dp"/>

                <ScrollView
                    android:id="@+id/svLogs"
                    android:layout_width="match_parent"
                    android:layout_height="140dp">

                    <TextView
                        android:id="@+id/tvLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:background="@color/code_bg"
                        android:padding="8dp"/>
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════ OUTPUT CARD ══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/accent_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OUTPUT"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:textColor="@color/accent_green"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvOutputCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 chars"
                        android:textSize="10sp"
                        android:textColor="@color/text_dim"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Output text -->
                <EditText
                    android:id="@+id/etOutput"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@color/code_bg"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:padding="10dp"
                    android:scrollbars="vertical"
                    android:focusable="true"
                    android:hint="Obfuscated output will appear here…"
                    android:textColorHint="@color/text_dim"/>

                <!-- Output buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveOutput"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="💾 Save"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:textColor="@color/accent_green"
                        app:strokeColor="@color/accent_green"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyOutput"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="📋 Copy"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        android:textColor="@color/bg_dark"
                        app:backgroundTint="@color/accent_green"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearOutput"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="✕"
                        android:textSize="12sp"
                        android:textColor="@color/text_dim"
                        app:strokeColor="@color/text_dim"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
